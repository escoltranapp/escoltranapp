generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AppRole {
  admin
  manager
  user
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum DealPriority {
  ALTA
  MEDIA
  BAIXA
}

enum ActivityType {
  CALL
  MEETING
  TASK
  NOTE
  WHATSAPP
  EMAIL
}

enum ActivityStatus {
  OPEN
  DONE
}

enum ListaDisparoStatus {
  ATIVA
  PAUSADA
  EM_PROCESSAMENTO
  CONCLUIDA
  CANCELADA
  RASCUNHO
}

enum LeadStatus {
  ATIVO
  INATIVO
  CONTATADO
  ADD_LISTA
  DISPARADO
}

enum StatusEnvio {
  PENDENTE
  ENVIADO
  FALHOU
  CANCELADO
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  n8nWebhookUrl              String?
  cnpjSearchWebhookUrl       String?
  disparoWebhookUrl          String?
  disparoCancelarWebhookUrl  String?
  disparoStatusWebhookUrl    String?

  accounts          Account[]
  sessions          Session[]
  teamMembers       TeamMember[]
  userRoles         UserRole[]
  historicoBuscas   HistoricoBusca[]
  historicoBuscasCnpj HistoricoBuscaCnpj[]
  listasDisparo     ListaDisparo[]
  messageTemplates  MessageTemplate[]
  aiAgentConfig     AiAgentConfig?
  leads             Lead[]
  leadsCnpj         LeadCnpj[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamMember[]

  @@map("teams")
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  createdAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model UserRole {
  id     String  @id @default(cuid())
  userId String
  role   AppRole @default(user)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_roles")
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages Stage[]
  deals  Deal[]

  @@map("pipelines")
}

model Stage {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#F97316")
  order       Int      @default(0)
  probability Float    @default(0)
  slaHours    Int?
  pipelineId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pipeline    Pipeline          @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]
  stageHistory DealStageHistory[]

  @@map("stages")
}

model Deal {
  id                String       @id @default(cuid())
  titulo            String
  valorEstimado     Float?
  produtoInteresse  String?
  origem            String?
  prioridade        DealPriority @default(MEDIA)
  status            DealStatus   @default(OPEN)
  motivoPerda       String?
  fechadoEm         DateTime?
  telefone          String?
  dataPrevista      DateTime?
  descricao         String?

  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmContent   String?
  utmTerm      String?
  landingPage  String?
  referrer     String?
  capturedAt   DateTime?

  aiScore               Float?
  aiAnalysis            String?
  aiRecommendedAction   String?
  aiScoreFactors        Json?
  qualificationStatus   String?

  userId     String
  contactId  String?
  stageId    String?
  pipelineId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  contact      Contact?           @relation(fields: [contactId], references: [id])
  stage        Stage?             @relation(fields: [stageId], references: [id])
  pipeline     Pipeline?          @relation(fields: [pipelineId], references: [id])
  activities   Activity[]
  stageHistory DealStageHistory[]
  aiSessions   AiQualificationSession[]

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("deals")
}

model DealStageHistory {
  id         String   @id @default(cuid())
  dealId     String
  stageId    String
  movedAt    DateTime @default(now())
  movedBy    String?

  deal  Deal  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  stage Stage @relation(fields: [stageId], references: [id])

  @@map("deal_stage_history")
}

model Contact {
  id            String   @id @default(cuid())
  nome          String
  sobrenome     String?
  email         String?
  telefone      String?
  empresa       String?
  cargo         String?
  status        String   @default("lead")
  etapaFunil    String   @default("Lead")
  canalOrigem   String?
  documento     String?
  dataNascimento DateTime?
  endereco      Json?
  tags          String[]
  notas         String?
  camposCustom  Json?
  lgpdConsent   Boolean  @default(false)

  utmSourceFirst    String?
  utmMediumFirst    String?
  utmCampaignFirst  String?
  utmContentFirst   String?
  utmTermFirst      String?
  landingPageFirst  String?
  referrerFirst     String?

  utmSourceLast    String?
  utmMediumLast    String?
  utmCampaignLast  String?
  utmContentLast   String?
  utmTermLast      String?
  landingPageLast  String?
  referrerLast     String?

  fbMetadata Json?

  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deals      Deal[]
  activities Activity[]
  purchases  Purchase[]
  messageLogs MessageLog[]
  trackingEvents TrackingEvent[]

  @@index([userId])
  @@index([createdAt])
  @@map("contacts")
}

model Purchase {
  id          String   @id @default(cuid())
  contactId   String
  produto     String
  valor       Float
  status      String?
  compradoEm  DateTime @default(now())
  metadata    Json?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Activity {
  id          String         @id @default(cuid())
  tipo        ActivityType
  status      ActivityStatus @default(OPEN)
  titulo      String
  descricao   String?
  dueAt       DateTime?
  doneAt      DateTime?
  contactId   String?
  dealId      String?
  ownerUserId String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  contact Contact? @relation(fields: [contactId], references: [id])
  deal    Deal?    @relation(fields: [dealId], references: [id])

  @@index([ownerUserId])
  @@index([status])
  @@map("activities")
}

model Lead {
  id       String     @id @default(cuid())
  nome     String
  telefone String?
  endereco String?
  cidade   String?
  uf       String?
  nicho    String?
  site     String?
  notas    String?
  status   LeadStatus @default(ATIVO)
  userId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  leadsListaDisparo LeadsListaDisparo[]

  @@index([userId])
  @@map("leads")
}

model LeadCnpj {
  id       String  @id @default(cuid())
  cnpj     String
  nome     String
  telefone String?
  cnae     String?
  cidade   String?
  uf       String?
  situacao String?
  email    String?
  notas    String?
  userId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  leadsListaDisparo LeadsListaDisparo[]

  @@index([userId])
  @@map("leads_cnpj")
}

model HistoricoBusca {
  id        String   @id @default(cuid())
  userId    String
  estado    String?
  cidade    String?
  nicho     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("historico_buscas")
}

model HistoricoBuscaCnpj {
  id        String   @id @default(cuid())
  userId    String
  estado    String?
  cidade    String?
  cnae      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("historico_buscas_cnpj")
}

model ListaDisparo {
  id          String             @id @default(cuid())
  nome        String
  descricao   String?
  status      ListaDisparoStatus @default(RASCUNHO)
  configEnvio Json?
  userId      String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  leadsListaDisparo LeadsListaDisparo[]

  @@index([userId])
  @@map("listas_disparo")
}

model LeadsListaDisparo {
  id          String      @id @default(cuid())
  listaId     String
  leadId      String?
  leadCnpjId  String?
  statusEnvio StatusEnvio @default(PENDENTE)
  tentativas  Int         @default(0)
  enviadoEm   DateTime?
  createdAt   DateTime    @default(now())

  lista    ListaDisparo @relation(fields: [listaId], references: [id], onDelete: Cascade)
  lead     Lead?        @relation(fields: [leadId], references: [id])
  leadCnpj LeadCnpj?   @relation(fields: [leadCnpjId], references: [id])

  @@map("leads_lista_disparo")
}

model MessageLog {
  id        String   @id @default(cuid())
  contactId String?
  canal     String?
  conteudo  String?
  status    String?
  createdAt DateTime @default(now())

  contact Contact? @relation(fields: [contactId], references: [id])

  @@map("message_logs")
}

model MessageTemplate {
  id        String   @id @default(cuid())
  nome      String
  canal     String   @default("WHATSAPP")
  conteudo  String
  variaveis String[]
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("message_templates")
}

model TrackingEvent {
  id        String   @id @default(cuid())
  contactId String?
  evento    String
  utmSource String?
  utmMedium String?
  utmCampaign String?
  utmContent String?
  utmTerm   String?
  landingPage String?
  referrer  String?
  metadata  Json?
  createdAt DateTime @default(now())

  contact Contact? @relation(fields: [contactId], references: [id])

  @@index([createdAt])
  @@map("tracking_events")
}

model WebhookLog {
  id        String   @id @default(cuid())
  tipo      String
  payload   Json?
  status    String?
  createdAt DateTime @default(now())

  @@map("webhook_logs")
}

model AiAgentConfig {
  id                    String   @id @default(cuid())
  userId                String   @unique
  modelo                String   @default("gpt-4")
  temperatura           Float    @default(0.7)
  maxTokens             Int      @default(1000)
  promptSistema         String?
  tomComunicacao        String   @default("profissional")
  permitirEmojis        Boolean  @default(false)
  scriptsAbertura       String?
  scriptsQualificacao   String?
  scriptsFechamentoPos  String?
  scriptsFechamentoNeg  String?
  scriptsObjecoes       String?
  bantScoreMinimo       Float    @default(0.6)
  bantCamposObrigatorios String[]
  bantMaxTentativas     Int      @default(3)
  acaoMoverStage        Boolean  @default(true)
  acaoCriarAtividade    Boolean  @default(true)
  acaoNotificar         Boolean  @default(true)
  acaoAdicionarTag      Boolean  @default(false)
  n8nWebhookUrl         String?
  evolutionInstanceId   String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("ai_agent_configs")
}

model AiQualificationSession {
  id         String   @id @default(cuid())
  sessionId  String   @unique
  dealId     String
  status     String   @default("active")
  scores     Json?
  mensagens  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  deal Deal @relation(fields: [dealId], references: [id])

  @@map("ai_qualification_sessions")
}

model AiConversationLog {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String
  canal     String?
  messageId String?
  createdAt DateTime @default(now())

  @@map("ai_conversation_logs")
}
